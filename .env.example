# Twilio SMS Configuration
# Get these credentials from https://www.twilio.com/

# Your Twilio Account SID (found in Twilio Console dashboard)
TWILIO_ACCOUNT_SID=AC1234567890abcdef1234567890

# Your Twilio Auth Token (found in Twilio Console dashboard)
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio Phone Number (assigned to your account, e.g., +1234567890)
TWILIO_PHONE_NUMBER=+1234567890
